# ==========================================
# Identidade da câmera simulada
# ==========================================
CAMERA_ID=cam_mock_portaria_01

# ==========================================
# Comportamento do disparo
# ==========================================
INTERVAL_SECONDS=5
# Modo de seleção de frames: "sequential" | "random"
FRAME_MODE=sequential
DATASET_PATH=./dataset

# ==========================================
# MinIO (Storage) — mesmo bucket do worker
# ==========================================
MINIO_ROOT_USER=visioncore_admin
MINIO_ROOT_PASSWORD=sua_senha_minio_aqui
MINIO_ENDPOINT=http://visioncore_minio:9000
MINIO_BUCKET_NAME=plate-bucket
MINIO_DATASET_PREFIX=dataset

# ==========================================
# Redis (Event Broker) — mesmo do parking-infra
# ==========================================
REDIS_HOST=parking_redis
REDIS_PORT=6379
REDIS_PASSWORD=sua_senha_redis_aqui
REDIS_QUEUE=camera:portaria:queue
